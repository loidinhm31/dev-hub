{
  "name": "dam-hopper",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @dam-hopper/web build",
    "dev": "pnpm --filter @dam-hopper/web dev --host",
    "dev:server:no-auth": "cd server && cargo run -- --no-auth",
    "dev:server": "cd server && cargo run",
    "dev:server:watch": "cd server && cargo watch -x run",
    "build:server": "cd server && cargo build --release",
    "serve": "cd server && cargo run --release",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "test": "cd server && cargo test",
    "test:run": "cd server && cargo test",
    "check": "pnpm build && pnpm lint && cd server && cargo test"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.0.0"
  }
}
