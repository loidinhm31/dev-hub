{
  "name": "dev-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @dev-hub/server dev:run",
    "dev:debug": "pnpm --filter @dev-hub/server dev:debug",
    "dev:electron": "pnpm --filter @dev-hub/electron dev",
    "build:electron": "pnpm --filter @dev-hub/electron build",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm build && pnpm lint && pnpm test:run"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@dev-hub/core": "workspace:*",
    "@dev-hub/server": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
