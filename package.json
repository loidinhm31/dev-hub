{
  "name": "dev-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @dev-hub/web build",
    "dev": "pnpm --filter @dev-hub/web dev --host",
    "dev:server": "cd server && cargo run",
    "dev:server:watch": "cd server && cargo watch -x run",
    "build:server": "cd server && cargo build --release",
    "serve": "cd server && cargo run --release",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "test": "cd server && cargo test",
    "test:run": "cd server && cargo test",
    "check": "pnpm build && pnpm lint && cd server && cargo test"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
